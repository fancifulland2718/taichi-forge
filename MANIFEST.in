include python/taichi_forge/*.md
recursive-include python/taichi_forge/assets *
recursive-include python/taichi_forge/examples *.py
include python/taichi_forge/examples/autodiff/diff_sph/fc1_pretrained.pkl
include python/taichi_forge/examples/autodiff/diff_sph/fc2_pretrained.pkl
include python/taichi_forge/examples/algorithm/circle-packing/taichi_logo.png
recursive-include python/taichi_forge/_lib/c_api *
include python/taichi_forge/_lib/core/*.so
include python/taichi_forge/_lib/core/*.pyd
include python/taichi_forge/_lib/runtime/*.bc
include python/taichi_forge/_lib/runtime/*.dylib
include python/taichi_forge/shaders/*.spv
include python/taichi_forge/shaders/*.vert
include python/taichi_forge/shaders/*.frag

global-exclude *.pyc *.pyo
global-exclude ffmpeg
